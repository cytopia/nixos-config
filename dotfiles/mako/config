# Behaviour
sort=-time

# Timeout
default-timeout=5000
ignore-timeout=1

# Appearance
font=monospace 14
text-alignment=left
text-color=#FFFFFFFF
background-color=#2e3440
layer=overlay

# Dimensions
width=300
height=110

# Border
border-size=2
border-color=#88c0d0
border-radius=15

# Icons
icons=1
#max-icon-size=64
#icon-path=/run/current-system/sw/share/icons/
#icon-path=/run/current-system/sw/share/icons/hicolor:/run/current-system/sw/share/icons/Adwaita



icon-path=/home/cytopia/.nix-profile/share/icons/Arc/:/home/cytopia/.nix-profile/share/icons/Moka/:/home/cytopia/.nix-profile/share/icons/Numix/:/home/cytopia/.nix-profile/share/icons/Numix-Cursor/:/home/cytopia/.nix-profile/share/icons/Numix-Cursor-Light/:/home/cytopia/.nix-profile/share/icons/Numix-Light/:/home/cytopia/.nix-profile/share/icons/Papirus/:/home/cytopia/.nix-profile/share/icons/Papirus-Dark/:/home/cytopia/.nix-profile/share/icons/Papirus-Light/:/home/cytopia/.nix-profile/share/icons/breeze/:/home/cytopia/.nix-profile/share/icons/gnome/:/home/cytopia/.nix-profile/share/icons/hicolor/:/home/cytopia/.nix-profile/share/icons/Adwaita/:/home/cytopia/.nix-profile/share/icons/HighContrast


[urgency=low]
border-color=#cccccc

[urgency=normal]
border-color=#d08770

[urgency=high]
border-color=#bf616a
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category
