# This section acts as your [urgency_normal] from Dunst
font=Monospace 10
text-alignment=left
width=400
height=150

layer=overlay

anchor=top-right
margin=10,20
padding=20
border-size=1

max-icon-size=32
icons=1
icon-path=/home/cytopia/.nix-profile/share/icons/breeze-dark/:/home/cytopia/.nix-profile/share/icons/default/:/home/cytopia/.nix-profile/share/icons/hicolor/

# Enable Pango markup
markup=1
format=<b>%s</b>\n%b


# --- Global / Urgency Normal ---
background-color=#24273a
text-color=#cad3f5
border-color=#8aadf4
progress-color=source #363a4f
default-timeout=10000

# --- Urgency High (Dunst Critical) ---
[urgency=high]
border-color=#f5a97f
default-timeout=0

# --- Urgency Low ---
[urgency=low]
default-timeout=10000
